datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  SUPER_ADMIN
  GYM_OWNER
  EMPLOYEE
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          Role      @default(EMPLOYEE)
  gymId         String?   // The gym this user belongs to
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  gymsOwned     Gym[]     @relation("GymOwner")
}

enum Plan {
  BASIC
  PRO
  ENTERPRISE
}

model Gym {
  id        String   @id @default(cuid())
  name      String
  ownerId   String
  plan      Plan     @default(BASIC)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt


  owner     User     @relation("GymOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  branches  Branch[] @relation("GymBranches")
  members   Member[] @relation("GymMembers")
}

model Branch {
  id        String   @id @default(cuid())
  gymId     String
  name      String
  address   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  gym       Gym      @relation("GymBranches", fields: [gymId], references: [id], onDelete: Cascade)
  members   Member[]
  agents    Agent[]
  attendance Attendance[]
}

model Member {
  id               String   @id @default(cuid())
  gymId            String
  branchId         String
  name             String
  rfidUid          String?  @unique
  membershipStatus String   @default("ACTIVE")
  membershipExpiry DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  gym              Gym      @relation("GymMembers", fields: [gymId], references: [id], onDelete: Cascade)
  branch           Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  attendance       Attendance[]
}

model Agent {
  id        String   @id @default(cuid())
  branchId  String
  apiKey    String   @unique
  name      String
  status    String   @default("OFFLINE")
  lastSeen  DateTime?
  createdAt DateTime @default(now())

  branch    Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  attendance Attendance[]
}

model Attendance {
  id        String   @id @default(cuid())
  memberId  String
  branchId  String
  agentId   String?
  timestamp DateTime @default(now())

  member    Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  branch    Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  agent     Agent?   @relation(fields: [agentId], references: [id], onDelete: SetNull)
}
